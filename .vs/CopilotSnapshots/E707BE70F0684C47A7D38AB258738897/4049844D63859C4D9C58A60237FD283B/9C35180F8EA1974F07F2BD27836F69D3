// Get combined access list (active sharers + pending invitations)
app.get('/api/my-access-list', authenticateToken, (req, res) => {
  const owner_id = req.user.id;

  // Get active permissions
  db.all(
    `SELECT p.viewer_id as id, u.username, u.email, 'active' as type, p.created_at as date_granted
     FROM permissions p
     JOIN users u ON p.viewer_id = u.id
     WHERE p.owner_id = ?`,
    [owner_id],
    (err, active) => {
      if (err) return res.status(500).json({ error: err.message });

      // Get pending invitations
      db.all(
        `SELECT id, invited_email as email, null as username, 'invited' as type, created_at as date_granted, expires_at
         FROM invitations 
         WHERE owner_id = ? AND status = 'pending' AND expires_at > CURRENT_TIMESTAMP`,
        [owner_id],
        (err, pending) => {
          if (err) return res.status(500).json({ error: err.message });

          const combined = [
            ...(active || []),
            ...(pending || [])
          ];
          res.json(combined);
        }
      );
    }
  );
});

