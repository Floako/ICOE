// Get shared data - viewer sees all categories/items from owner
app.get('/api/shared-with-me', authenticateToken, (req, res) => {
  const viewer_id = req.user.id;

  // Get all owners who shared with this user
  db.all(
    `SELECT DISTINCT p.owner_id, u.username, u.email
     FROM permissions p
     JOIN users u ON p.owner_id = u.id
     WHERE p.viewer_id = ?`,
    [viewer_id],
    (err, owners) => {
      if (err) return res.status(500).json({ error: err.message });

      if (!owners || owners.length === 0) {
        return res.json([]);
      }

      // For each owner, get their categories and items
      const sharedData = owners.map(owner => ({
        owner_id: owner.owner_id,
        owner_username: owner.username,
        owner_email: owner.email,
        categories: []
      }));

      let processed = 0;
      owners.forEach((owner, ownerIndex) => {
        db.all(
          'SELECT id, category_name FROM categories WHERE user_id = ?',
          [owner.owner_id],
          (err, categories) => {
            if (!err && categories) {
              sharedData[ownerIndex].categories = categories;
            }
            processed++;
            if (processed === owners.length) {
              res.json(sharedData);
            }
          }
        );
      });
    }
  );
});

// Get items from shared category (with permission check)
