// SHARING ENDPOINTS

// Get all users (for search/nominate)
app.get('/api/users', authenticateToken, (req, res) => {
  const { search } = req.query;
  let query = 'SELECT id, username, email, "registered" as status FROM users WHERE id != ?';
  let params = [req.user.id];

  if (search) {
    query += ' AND (username LIKE ? OR email LIKE ?)';
    params.push(`%${search}%`, `%${search}%`);
  }

  db.all(query, params, (err, rows) => {
    if (err) return res.status(500).json({ error: err.message });
    
    // If search term provided, also check for unregistered invites
    if (search && search.includes('@')) {
      db.get(
        'SELECT DISTINCT invited_email FROM invitations WHERE invited_email LIKE ? AND status = ? AND expires_at > CURRENT_TIMESTAMP',
        [`%${search}%`, 'pending'],
        (err, invite) => {
          if (invite && !rows.find(u => u.email === invite.invited_email)) {
            rows.push({
              id: null,
              username: invite.invited_email.split('@')[0],
              email: invite.invited_email,
              status: 'invited'
            });
          }
          res.json(rows || []);
        }
      );
    } else {
      res.json(rows || []);
    }
  });
});

// Share data - owner grants access to viewer
app.post('/api/share', authenticateToken, (req, res) => {
  const { viewer_id } = req.body;
  const owner_id = req.user.id;

  if (!viewer_id) {
    return res.status(400).json({ error: 'Missing viewer_id' });
  }

  // Check if viewer exists
  db.get('SELECT id FROM users WHERE id = ?', [viewer_id], (err, user) => {
    if (err || !user) {
      return res.status(404).json({ error: 'User not found' });
    }

    // Insert or update permission
    db.run(
      'INSERT OR REPLACE INTO permissions (owner_id, viewer_id, access_level) VALUES (?, ?, ?)',
      [owner_id, viewer_id, 'view'],
      function(err) {
        if (err) return res.status(500).json({ error: err.message });
        res.status(201).json({ message: 'Access granted', viewer_id });
      }
    );
  });
});

// Revoke access - owner removes viewer
app.delete('/api/share/:viewerId', authenticateToken, (req, res) => {
  const owner_id = req.user.id;
  const viewer_id = req.params.viewerId;

  db.run(
    'DELETE FROM permissions WHERE owner_id = ? AND viewer_id = ?',
    [owner_id, viewer_id],
    function(err) {
      if (err) return res.status(500).json({ error: err.message });
      if (this.changes === 0) {
        return res.status(404).json({ error: 'Permission not found' });
      }
      res.json({ message: 'Access revoked' });
    }
  );
});

