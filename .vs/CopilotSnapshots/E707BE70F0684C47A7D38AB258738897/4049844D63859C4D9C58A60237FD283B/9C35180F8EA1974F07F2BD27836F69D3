        (err, rows) => {
          if (err) return res.status(500).json({ error: err.message });
          res.json(rows || []);
        }
      );
    }
  );
});

// INVITATION ENDPOINTS

// Send invite to unregistered user
app.post('/api/invite', authenticateToken, (req, res) => {
  const { invited_email } = req.body;
  const owner_id = req.user.id;
  const ownerUsername = req.user.username;

  if (!invited_email) {
    return res.status(400).json({ error: 'Missing invited_email' });
  }

  // Check if email is already registered
  db.get('SELECT id FROM users WHERE email = ?', [invited_email], (err, user) => {
    if (user) {
      // User exists, just grant access directly instead
      return res.status(400).json({ error: 'User already registered - use Share Data instead' });
    }

    // Calculate 48 hours from now
    const expiresAt = new Date(Date.now() + 48 * 60 * 60 * 1000).toISOString();

    // Insert invitation (or update if exists)
    db.run(
      'INSERT OR REPLACE INTO invitations (owner_id, invited_email, status, expires_at) VALUES (?, ?, ?, ?)',
      [owner_id, invited_email, 'pending', expiresAt],
      async function(err) {
        if (err) return res.status(500).json({ error: err.message });
        
        // Send invitation email
        const invitationLink = `${process.env.FRONTEND_URL || 'http://localhost:3000'}/register?invited_email=${encodeURIComponent(invited_email)}`;
        await sendInvitationEmail(invited_email, ownerUsername, invitationLink);
        
        res.status(201).json({ 
          message: 'Invitation sent', 
          invited_email,
          expires_at: expiresAt
        });
      }
    );
  });
});

